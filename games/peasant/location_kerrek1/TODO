updateKerrek
	if kerrek_x>player_x then kerrek_dir=left,x-=walk_speed
	else kerrek_dir=right,x+=walk_speed

	if kerrek_y+kerrek_height>player_y+player_height move up
	else move down (by walkspeed)

	if abs(kerrek_y+kerrek_height - player_y+player_height)
		+ abs(kerrek_x-player_x)  < 50 then start collision?

	start_collision
		stop input
		if above equation <40 then start attack
			make player invisible
			start animation
			show text
			gameover

		else
			keep walking toward you with speed being +/-2


